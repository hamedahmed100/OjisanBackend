// Jenkins server: http://144.91.70.227:8080
// API runs on a different host port (API_HOST_PORT) so it does not conflict with Jenkins on 8080.
// Run this pipeline from the server (Contabo VPS) so Docker build/run execute there.
pipeline {
    agent any

    environment {
        CONTAINER_NAME = 'ojisan-api'
        IMAGE_NAME = 'ojisan-api'
        IMAGE_TAG = "${BUILD_NUMBER}"
        API_HOST_PORT = '5000'   // Host port for the API (Jenkins uses 8080)
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build -f docker/Dockerfile -t ${IMAGE_NAME}:${IMAGE_TAG} .
                """
            }
        }

        stage('Stop Existing Container') {
            steps {
                script {
                    def running = sh(
                        script: "docker ps -q -f name=^/${CONTAINER_NAME}\$",
                        returnStdout: true
                    ).trim()
                    if (running) {
                        sh "docker stop ${CONTAINER_NAME}"
                    }
                }
            }
        }

        stage('Remove Existing Container') {
            steps {
                script {
                    def existing = sh(
                        script: "docker ps -aq -f name=^/${CONTAINER_NAME}\$",
                        returnStdout: true
                    ).trim()
                    if (existing) {
                        sh "docker rm ${CONTAINER_NAME}"
                    }
                }
            }
        }

        stage('Verify Credentials') {
            steps {
                withCredentials([
                    string(credentialsId: 'DB_CONNECTION_STRING', variable: 'DB_CONNECTION_STRING'),
                    string(credentialsId: 'S3_ACCESS_KEY',        variable: 'S3_ACCESS_KEY'),
                    string(credentialsId: 'S3_SECRET_KEY',        variable: 'S3_SECRET_KEY'),
                    string(credentialsId: 'S3_BUCKET',            variable: 'S3_BUCKET'),
                    string(credentialsId: 'S3_ENDPOINT',          variable: 'S3_ENDPOINT'),
                    string(credentialsId: 'S3_PUBLIC_BASE_URL',   variable: 'S3_PUBLIC_BASE_URL'),
                ]) {
                    sh '''
                        echo "=== Credential Check ==="
                        [ -n "$DB_CONNECTION_STRING" ] && echo "✅ DB_CONNECTION_STRING is set" || echo "❌ DB_CONNECTION_STRING is EMPTY"
                        [ -n "$S3_ACCESS_KEY" ]        && echo "✅ S3_ACCESS_KEY is set"        || echo "❌ S3_ACCESS_KEY is EMPTY"
                        [ -n "$S3_SECRET_KEY" ]        && echo "✅ S3_SECRET_KEY is set"        || echo "❌ S3_SECRET_KEY is EMPTY"
                        [ -n "$S3_BUCKET" ]            && echo "✅ S3_BUCKET is set"            || echo "❌ S3_BUCKET is EMPTY"
                        [ -n "$S3_ENDPOINT" ]          && echo "✅ S3_ENDPOINT is set"          || echo "❌ S3_ENDPOINT is EMPTY"
                        [ -n "$S3_PUBLIC_BASE_URL" ]   && echo "✅ S3_PUBLIC_BASE_URL is set"   || echo "❌ S3_PUBLIC_BASE_URL is EMPTY"
                        echo "=== End Check ==="
                    '''
                }
            }
        }

        stage('Run New Container') {
            steps {
                // Use single-quoted sh so $VAR is expanded by the shell from withCredentials env, not by Groovy.
                // ConnectionStrings__OjisanBackendDb (env) overrides appsettings.json at runtime. Set the credential to the
                // same value as appsettings (Server=sqlserver-student,1433;Database=OjiSanDbPlatform_;User Id=DEV;...) or your production connection string.
                // In Manage Jenkins → Credentials, add: DB_CONNECTION_STRING, s3-access-key, s3-secret-key (Kind: Secret text).
                withCredentials([
                    string(credentialsId: 'DB_CONNECTION_STRING', variable: 'DB_CONNECTION_STRING'),
                    string(credentialsId: 's3-access-key', variable: 'S3_ACCESS_KEY'),
                    string(credentialsId: 's3-secret-key', variable: 'S3_SECRET_KEY')
                ]) {
                    sh '''
                        docker run -d \
                            --name ''' + env.CONTAINER_NAME + ''' \
                            --restart unless-stopped \
                            -p ''' + env.API_HOST_PORT + ''':8080 \
                            -e ASPNETCORE_ENVIRONMENT=Production \
                            -e ASPNETCORE_URLS=http://+:8080 \
                            -e ConnectionStrings__OjisanBackendDb="$DB_CONNECTION_STRING" \
                            -e S3_ACCESS_KEY="$S3_ACCESS_KEY" \
                            -e S3_SECRET_KEY="$S3_SECRET_KEY" \
                            -e S3_BUCKET="${S3_BUCKET:-photos}" \
                            -e S3_ENDPOINT="${S3_ENDPOINT:-https://eu2.contabostorage.com}" \
                            -e S3_PUBLIC_BASE_URL="$S3_PUBLIC_BASE_URL" \
                            ''' + env.IMAGE_NAME + ':' + env.IMAGE_TAG + '''
                    '''
                }
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed. Check logs above.'
            // Optional: notify, archive logs, etc.
        }
        success {
            echo "Deployed ${IMAGE_NAME}:${IMAGE_TAG}"
            // Optional: tag as 'latest', push to registry, etc.
        }
        always {
            cleanWs(deleteDirs: true, patterns: [[pattern: '.git', type: 'INCLUDE']])
        }
    }
}
